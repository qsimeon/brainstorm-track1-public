# Local Environment Variables for Mind Meld
# Copy this file to .env.local and update with your local paths
# .env.local is git-ignored and specific to your machine

# Checkpoint directory for saving best models during training
# This allows each developer to use their own storage location
CHECKPOINT_DIR=./checkpoints

# Optional: GPU device selection (0, 1, 2, ... or cpu)
# DEVICE=0

# Optional: Number of workers for data loading
# NUM_WORKERS=4
